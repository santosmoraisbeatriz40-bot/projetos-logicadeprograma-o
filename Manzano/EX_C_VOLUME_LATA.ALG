Algoritmo "ex_volume_lata"
// Disciplina   : Lógica de Programaçăo com Visualg
// Professor    : Jailson Costa dos Santos
// Descriçăo    : Calcular o volume de uma lata de óleo
// Autor(a)     : Beatriz Prates Dos Santos Morais
// Data atual   : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   raio, altura, volume: real


Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreval("Digite o valor do raio: ")
   leia(raio)
   escreval("Digite o valor da altura: ")
   leia(altura)

   volume <- 3.14 * raio * altura

   escreval("Volume da lata: ", volume)


Fimalgoritmo