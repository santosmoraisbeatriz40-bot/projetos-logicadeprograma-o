Algoritmo "ex_extra_b_salario"
// Disciplina   : Lógica de Programaçăo com Visualg
// Professor    : Jailson Costa dos Santos
// Descriçăo    : Calcular o novo salario com reajuste
// Autor(a)     : Beatriz Prates Dos Santos Morais
// Data atual   : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   sm, pr, ns: real
Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreval("Digite o salario mensal: ")
   Leia(sm)
   Escreval("Digite o percentual de reajuste: ")
   Leia(pr)
   ns <- sm + (sm * pr / 100)
   Escreval("Novo salario: R$ ", ns)

Fimalgoritmo