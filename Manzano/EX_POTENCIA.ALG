Algoritmo "ex_potencia"
// Disciplina   : Lógica de Programaçăo com Visualg
// Professor    : Jailson Costa dos Santos
// Descriçăo    : Calcular a potencia de uma base e expoente qualquer
// Autor(a)     : Beatriz Prates Dos Santos Morais
// Data atual   : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   base, expoente, contador, resultado: inteiro
Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreval("Digite a base: ")
   Leia(base)
   Escreval("Digite o expoente: ")
   Leia(expoente)
   resultado <- 1
   contador <- 1
   Enquanto contador <= expoente Faca
      resultado <- resultado * base
      contador <- contador + 1
   FimEnquanto
   Escreval(base, " ^ ", expoente, " = ", resultado)
Fimalgoritmo