Algoritmo "ex_fatorial_soma"
// Disciplina   : Lógica de Programaçăo com Visualg
// Professor    : Jailson Costa dos Santos
// Descriçăo    : Somar a fatorial de 15 valores lidos
// Autor(a)     : Beatriz Prates Dos Santos Morais
// Data atual   : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   numero, contador, fatorial, somatorio, aux: inteiro
Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   somatorio <- 0
   contador <- 1
   Enquanto contador <= 15 Faca
      Escreval("Digite o numero ", contador, ": ")
      Leia(numero)
      fatorial <- 1
      aux <- 1
      Enquanto aux <= numero Faca
         fatorial <- fatorial * aux
         aux <- aux + 1
      FimEnquanto
      somatorio <- somatorio + fatorial
      contador <- contador + 1
   FimEnquanto
   Escreval("Somatorio das fatoriais: ", somatorio)
Fimalgoritmo