Algoritmo "ex_h_volume_caixa"
// Disciplina   : Lógica de Programaçăo com Visualg
// Professor    : Jailson Costa dos Santos
// Descriçăo    : Calcular o volume de uma caixa retangular
// Autor(a)     : Beatriz Prates Dos Santos Morais
// Data atual   : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   comprimento, largura, altura, volume: real
Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreval("Digite o comprimento: ")
   Leia(comprimento)
   Escreval("Digite a largura: ")
   Leia(largura)
   Escreval("Digite a altura: ")
   Leia(altura)
   volume <- comprimento * largura * altura
   Escreval("Volume da caixa: ", volume)

Fimalgoritmo